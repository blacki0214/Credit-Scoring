{
  "displayName": "Export Function Errors - firestore exporter",
  "severity": "ERROR",
  "documentation": {
    "content": "Alert when export function emits error logs.",
    "mimeType": "text/markdown"
  },
  "combiner": "OR",
  "enabled": true,
  "conditions": [
    {
      "displayName": "Export function error log match",
      "conditionMatchedLog": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"export-firestore-to-gcs\" AND severity>=ERROR"
      }
    }
  ],
  "alertStrategy": {
    "autoClose": "1800s",
    "notificationRateLimit": {
      "period": "300s"
    }
  }
}
